VITE_LEAD_API_URL=https://your-project.vercel.app/api/submit-lead

# Server-only (Vercel environment variables — never expose in the client)
# GHL_WEBHOOK_URL=https://rest.gohighlevel.com/v1/your-webhook-endpoint
# GHL_LANDING_WEBHOOK_URL=https://rest.gohighlevel.com/v1/your-landing-webhook-endpoint
# LEAD_SKIP_GHL=true  # optional: skip GHL errors while testing email-only (remove in production)
# ALLOWED_ORIGIN=https://stuartga.github.io

# Solicitud de cotización (server-only, Vercel)
# SITE_PUBLIC_URL=https://stuartga.github.io/leadhub-ecommerce
# Replace re_xxxxxxxxx with your real key from https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxx
# QUOTE_NOTIFICATION_EMAIL=gapstu@gmail.com
# QUOTE_EMAIL_FROM="San Patric Cotizaciones <onboarding@resend.dev>"

# Sanity CMS (Headless)
VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-05-01
VITE_SANITY_USE_CDN=true

# Solo para scripts de importación/subida (nunca en el cliente)
# SANITY_API_TOKEN=sk...

# Tracking & Analytics
